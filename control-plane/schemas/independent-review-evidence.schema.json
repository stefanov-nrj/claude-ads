{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AI-Marketing-Hub/claude-ads/schemas/independent-review-evidence.v1.json",
  "title": "Claude Ads independent review evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "review_type",
    "subject",
    "reviewer",
    "reviewed_at",
    "decision",
    "evidence_refs",
    "findings",
    "authentication"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "review_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
    },
    "review_type": {
      "enum": ["code", "evidence", "security", "privacy", "licensing"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit_sha", "tree_sha"],
      "properties": {
        "repository": {
          "const": "https://github.com/AI-Marketing-Hub/claude-ads"
        },
        "commit_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{40}$"
        },
        "tree_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "independence_basis", "conflict_disclosure"],
      "properties": {
        "id": {"type": ["string", "null"], "minLength": 3, "maxLength": 128},
        "independence_basis": {
          "type": ["string", "null"],
          "minLength": 20,
          "maxLength": 1000
        },
        "conflict_disclosure": {
          "type": ["string", "null"],
          "minLength": 4,
          "maxLength": 1000
        }
      }
    },
    "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
    "decision": {"enum": ["pending", "approved", "rejected"]},
    "evidence_refs": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "locator", "sha256"],
        "properties": {
          "kind": {
            "enum": [
              "ci-run",
              "command-output",
              "diff",
              "document",
              "issue",
              "pull-request",
              "report",
              "source-ledger",
              "test-artifact"
            ]
          },
          "locator": {"type": "string", "minLength": 1, "maxLength": 1000},
          "sha256": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "status",
          "title",
          "evidence_refs",
          "resolution"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9-]{2,63}$"
          },
          "severity": {"enum": ["critical", "high", "medium", "low", "informational"]},
          "status": {"enum": ["open", "resolved", "accepted-risk"]},
          "title": {"type": "string", "minLength": 3, "maxLength": 500},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": {"type": "integer", "minimum": 0}
          },
          "resolution": {"type": ["string", "null"], "maxLength": 2000}
        }
      }
    },
    "authentication": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "key_id", "signature_b64url"],
          "properties": {
            "algorithm": {"const": "ed25519"},
            "key_id": {"type": "string", "minLength": 3, "maxLength": 128},
            "signature_b64url": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{86}(?:==)?$"
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"decision": {"const": "pending"}}},
      "then": {
        "properties": {
          "subject": {
            "properties": {
              "commit_sha": {"type": "null"},
              "tree_sha": {"type": "null"}
            }
          },
          "reviewer": {
            "properties": {
              "id": {"type": "null"},
              "independence_basis": {"type": "null"},
              "conflict_disclosure": {"type": "null"}
            }
          },
          "reviewed_at": {"type": "null"},
          "evidence_refs": {"maxItems": 0},
          "findings": {"maxItems": 0},
          "authentication": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "subject": {
            "properties": {
              "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
              "tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
            }
          },
          "reviewer": {
            "properties": {
              "id": {"type": "string", "minLength": 3},
              "independence_basis": {"type": "string", "minLength": 20},
              "conflict_disclosure": {"type": "string", "minLength": 4}
            }
          },
          "reviewed_at": {"type": "string", "format": "date-time"},
          "evidence_refs": {"minItems": 1},
          "authentication": {"type": "object"}
        }
      }
    }
  ]
}
