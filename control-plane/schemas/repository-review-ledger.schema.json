{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AI-Marketing-Hub/claude-ads/schemas/repository-review-ledger.v1.json",
  "title": "Claude Ads repository and fork review ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewed_at",
    "clean_room_policy",
    "disposition_semantics",
    "fork_survey",
    "repositories",
    "tracker_scopes",
    "tracker_items",
    "critical_blockers"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewed_at": {"type": "string", "format": "date"},
    "clean_room_policy": {"const": "concepts-only-no-code-or-prose"},
    "disposition_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adopt", "already-addressed", "defer", "reject"],
      "properties": {
        "adopt": {"type": "string", "minLength": 1},
        "already-addressed": {"type": "string", "minLength": 1},
        "defer": {"type": "string", "minLength": 1},
        "reject": {"type": "string", "minLength": 1}
      }
    },
    "fork_survey": {"$ref": "#/$defs/fork_survey"},
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/repository_review"}
    },
    "tracker_scopes": {
      "type": "array",
      "items": {"$ref": "#/$defs/tracker_scope"}
    },
    "tracker_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/tracker_item"}
    },
    "critical_blockers": {
      "type": "array",
      "items": {"$ref": "#/$defs/critical_blocker"}
    }
  },
  "$defs": {
    "disposition": {
      "enum": ["adopt", "already-addressed", "defer", "reject"]
    },
    "fork_survey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstream_repository",
        "upstream_default_branch",
        "upstream_head_sha",
        "enumerated_at",
        "method",
        "paginated_fork_count",
        "repository_counter_observed",
        "ancestor_or_equal_count",
        "non_ancestor_count",
        "completeness",
        "non_ancestor_repository_ids"
      ],
      "properties": {
        "upstream_repository": {"const": "AgriciDaniel/claude-ads"},
        "upstream_default_branch": {"const": "main"},
        "upstream_head_sha": {"$ref": "#/$defs/sha"},
        "enumerated_at": {"type": "string", "format": "date"},
        "method": {"const": "github-rest-paginated-forks-and-default-head-ancestry"},
        "paginated_fork_count": {"type": "integer", "minimum": 0},
        "repository_counter_observed": {"type": "integer", "minimum": 0},
        "ancestor_or_equal_count": {"type": "integer", "minimum": 0},
        "non_ancestor_count": {"type": "integer", "minimum": 0},
        "completeness": {"const": "complete"},
        "non_ancestor_repository_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^fork-[a-z0-9-]+$"},
          "uniqueItems": true
        }
      }
    },
    "repository_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository",
        "relationship",
        "source_url",
        "default_branch",
        "reviewed_head_sha",
        "reviewed_at",
        "license_spdx",
        "license_use",
        "copy_policy",
        "head_review",
        "primary_disposition",
        "rationale",
        "actionable_concepts"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^(fork|repo)-[a-z0-9-]+$"},
        "repository": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
        "relationship": {"enum": ["fork", "external"]},
        "source_url": {"type": "string", "format": "uri", "pattern": "^https://github\\.com/"},
        "default_branch": {"type": "string", "minLength": 1},
        "reviewed_head_sha": {"$ref": "#/$defs/sha"},
        "reviewed_at": {"type": "string", "format": "date"},
        "license_spdx": {"enum": ["MIT", "Apache-2.0", "NOASSERTION"]},
        "license_use": {
          "enum": [
            "same-project-metadata-only",
            "compatible-metadata-only",
            "unverified-metadata-only"
          ]
        },
        "copy_policy": {"const": "concepts-only-no-code-or-prose"},
        "head_review": {"$ref": "#/$defs/head_review"},
        "primary_disposition": {"$ref": "#/$defs/disposition"},
        "rationale": {"type": "string", "minLength": 1},
        "actionable_concepts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/actionable_concept"}
        }
      }
    },
    "head_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "surfaces"],
      "properties": {
        "method": {
          "enum": [
            "github-rest-compare",
            "github-rest-compare-plus-tree",
            "github-rest-tree-and-metadata"
          ]
        },
        "compare_status": {"enum": ["ahead", "diverged", "no-common-ancestor"]},
        "upstream_base_sha": {"$ref": "#/$defs/sha"},
        "merge_base_sha": {"$ref": "#/$defs/sha"},
        "ahead_by": {"type": "integer", "minimum": 0},
        "behind_by": {"type": "integer", "minimum": 0},
        "commit_count": {"type": "integer", "minimum": 0},
        "changed_files": {"type": "integer", "minimum": 0},
        "additions": {"type": "integer", "minimum": 0},
        "deletions": {"type": "integer", "minimum": 0},
        "tree_blob_count": {"type": "integer", "minimum": 0},
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "uniqueItems": true
        }
      }
    },
    "actionable_concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "disposition", "rationale", "requirement_ids"],
      "properties": {
        "id": {"type": "string", "pattern": "^RC-[0-9]{4}$"},
        "summary": {"type": "string", "minLength": 1},
        "disposition": {"$ref": "#/$defs/disposition"},
        "rationale": {"type": "string", "minLength": 1},
        "requirement_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^REQ-[A-Z]+-[0-9]{3}$"},
          "uniqueItems": true
        }
      }
    },
    "tracker_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "reviewed_at",
        "state_filter",
        "completeness",
        "issue_count",
        "pull_request_count",
        "item_ids"
      ],
      "properties": {
        "repository": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
        "reviewed_at": {"type": "string", "format": "date"},
        "state_filter": {"const": "all"},
        "completeness": {"const": "complete"},
        "issue_count": {"type": "integer", "minimum": 0},
        "pull_request_count": {"type": "integer", "minimum": 0},
        "item_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^TRK-[0-9]{4}$"},
          "uniqueItems": true
        }
      }
    },
    "tracker_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository",
        "kind",
        "number",
        "url",
        "state",
        "merged",
        "reviewed_at",
        "disposition",
        "rationale",
        "linked_concept_ids"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^TRK-[0-9]{4}$"},
        "repository": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
        "kind": {"enum": ["issue", "pull-request"]},
        "number": {"type": "integer", "minimum": 1},
        "url": {"type": "string", "format": "uri", "pattern": "^https://github\\.com/"},
        "state": {"enum": ["open", "closed"]},
        "merged": {"type": "boolean"},
        "reviewed_at": {"type": "string", "format": "date"},
        "disposition": {"$ref": "#/$defs/disposition"},
        "rationale": {"type": "string", "minLength": 1},
        "linked_concept_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^RC-[0-9]{4}$"},
          "uniqueItems": true
        }
      }
    },
    "critical_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "status", "summary", "evidence_paths"],
      "properties": {
        "id": {"type": "string", "pattern": "^REPO-BLK-[0-9]{3}$"},
        "severity": {"const": "critical"},
        "status": {"enum": ["open", "resolved"]},
        "summary": {"type": "string", "minLength": 1},
        "evidence_paths": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
  }
}
