{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/generation-manifest.schema.json", "title": "GenerationManifest v1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "created_at", "provider", "inputs", "outputs", "failures", "human_review", "status"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "generation-manifest"}, "run_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "created_at": {"$ref": "workflow-common.schema.json#/$defs/datetime"},
    "provider": {"type": "object", "additionalProperties": false, "required": ["id", "model", "capability_evidence"], "properties": {"id": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "model": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "capability_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}},
    "inputs": {"type": "object", "additionalProperties": false, "required": ["creative_brief_sha256", "brand_profile_sha256", "source_assets"], "properties": {"creative_brief_sha256": {"$ref": "workflow-common.schema.json#/$defs/sha256"}, "brand_profile_sha256": {"$ref": "workflow-common.schema.json#/$defs/sha256"}, "source_assets": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "rights_confirmed"], "properties": {"path": {"$ref": "workflow-common.schema.json#/$defs/relative_path"}, "sha256": {"$ref": "workflow-common.schema.json#/$defs/sha256"}, "rights_confirmed": {"type": "boolean"}}}}}},
    "outputs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["asset_id", "path", "sha256", "media_type", "width", "height", "prompt_version", "status", "cost"], "properties": {"asset_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "path": {"$ref": "workflow-common.schema.json#/$defs/relative_path"}, "sha256": {"$ref": "workflow-common.schema.json#/$defs/sha256"}, "media_type": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}, "prompt_version": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "status": {"enum": ["generated", "validated", "rejected"]}, "cost": {"type": ["object", "null"], "additionalProperties": false, "required": ["currency", "amount"], "properties": {"currency": {"type": "string", "pattern": "^[A-Z]{3}$"}, "amount": {"type": "number", "minimum": 0}}}}}},
    "failures": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["input_id", "reason", "recovery_hint"], "properties": {"input_id": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "reason": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "recovery_hint": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}},
    "human_review": {"enum": ["pending", "approved", "rejected"]}, "status": {"$ref": "workflow-common.schema.json#/$defs/artifact_status"}
  }
}
