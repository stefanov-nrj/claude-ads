{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/run-manifest.schema.json",
  "title": "RunManifest v1",
  "type": "object",
  "required": ["schema_version", "run_id", "started_at", "scopes", "adapters", "sources", "privacy_class", "data_lifecycle", "worker_status", "completeness"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "started_at": {"type": "string", "format": "date-time"},
    "scopes": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "mode"],
        "properties": {
          "platform": {"enum": ["google", "meta", "youtube", "linkedin", "tiktok", "microsoft", "apple", "amazon", "reddit", "pinterest", "snapchat", "x"]},
          "mode": {"enum": ["export", "live_read", "write_preview", "write_apply"]}
        },
        "additionalProperties": true
      }
    },
    "sources": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "privacy_class": {"enum": ["public", "internal", "confidential", "restricted"]},
    "data_lifecycle": {"$ref": "data-lifecycle.schema.json"},
    "worker_status": {
      "type": "object",
      "additionalProperties": {"enum": ["pending", "running", "completed", "failed", "skipped"]}
    },
    "completeness": {"enum": ["complete", "partial", "failed"]}
  },
  "additionalProperties": true
}
