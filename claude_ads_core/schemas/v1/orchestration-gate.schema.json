{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/orchestration-gate.schema.json", "title": "OrchestrationGate v1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "gate_id", "run_id", "stage", "evaluated_at", "evaluator", "required_task_ids", "evaluated_result_ids", "checks", "decision", "blockers"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "orchestration-gate"}, "gate_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "run_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "stage": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "evaluated_at": {"$ref": "workflow-common.schema.json#/$defs/datetime"}, "evaluator": {"const": "artifact-only-v1"}, "required_task_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "workflow-common.schema.json#/$defs/id"}}, "evaluated_result_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "workflow-common.schema.json#/$defs/id"}},
    "checks": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "passed", "evidence_refs", "message"], "properties": {"id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "passed": {"type": "boolean"}, "evidence_refs": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "message": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}}, "decision": {"enum": ["pass", "fail"]}, "blockers": {"$ref": "workflow-common.schema.json#/$defs/string_array"}
  }
}
