{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/media-plan.schema.json", "title": "MediaPlan v1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "created_at", "objective", "currency", "channels", "actions", "assumptions", "exclusions", "status"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "media-plan"}, "run_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "created_at": {"$ref": "workflow-common.schema.json#/$defs/datetime"}, "objective": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "channels": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["platform", "role", "rationale", "budget_amount", "prerequisites", "exclusions"], "properties": {"platform": {"$ref": "workflow-common.schema.json#/$defs/platform"}, "role": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "rationale": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "budget_amount": {"type": ["number", "null"], "minimum": 0}, "prerequisites": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "exclusions": {"$ref": "workflow-common.schema.json#/$defs/string_array"}}}},
    "actions": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "description", "owner", "timing", "dependencies", "evidence_refs", "success_measure", "rollback_or_exit"], "properties": {"id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "description": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "owner": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "timing": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "dependencies": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "evidence_refs": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "success_measure": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "rollback_or_exit": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}},
    "assumptions": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "exclusions": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "status": {"$ref": "workflow-common.schema.json#/$defs/artifact_status"}
  }
}
