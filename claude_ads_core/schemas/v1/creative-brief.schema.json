{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/creative-brief.schema.json", "title": "CreativeBrief v1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "created_at", "objective", "audience", "offer", "approved_claims", "hypotheses", "copy_deck", "specification_source_ids", "human_review", "status", "data_lifecycle"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "creative-brief"}, "run_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "created_at": {"$ref": "workflow-common.schema.json#/$defs/datetime"}, "objective": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "audience": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "offer": {"$ref": "workflow-common.schema.json#/$defs/nonempty"},
    "approved_claims": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["claim", "evidence_refs"], "properties": {"claim": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}}},
    "hypotheses": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "insight", "promise", "hook", "cta", "platforms", "experiment_hypothesis"], "properties": {"id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "insight": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "promise": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "hook": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "cta": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "platforms": {"type": "array", "minItems": 1, "items": {"$ref": "workflow-common.schema.json#/$defs/platform"}}, "experiment_hypothesis": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}},
    "copy_deck": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["hypothesis_id", "platform", "placement", "fields"], "properties": {"hypothesis_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "platform": {"$ref": "workflow-common.schema.json#/$defs/platform"}, "placement": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "fields": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["name", "value"], "properties": {"name": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "value": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}}}}},
    "specification_source_ids": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "human_review": {"enum": ["pending", "approved", "rejected"]}, "status": {"$ref": "workflow-common.schema.json#/$defs/artifact_status"}, "data_lifecycle": {"$ref": "data-lifecycle.schema.json"}
  }
}
