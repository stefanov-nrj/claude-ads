{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/orchestration-result.schema.json", "title": "OrchestrationResult v1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "result_id", "task_id", "run_id", "role", "created_at", "status", "output_artifacts", "evidence_refs", "summary", "blockers", "recovery_hints", "supersedes"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "orchestration-result"}, "result_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "task_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "run_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "role": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "created_at": {"$ref": "workflow-common.schema.json#/$defs/datetime"}, "status": {"enum": ["ok", "needs_input", "blocked", "failed"]},
    "output_artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "contract", "sha256"], "properties": {"path": {"$ref": "workflow-common.schema.json#/$defs/relative_path"}, "contract": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "sha256": {"$ref": "workflow-common.schema.json#/$defs/sha256"}}}},
    "evidence_refs": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "summary": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "blockers": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "recovery_hints": {"$ref": "workflow-common.schema.json#/$defs/string_array"}, "supersedes": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"}
  }
}
