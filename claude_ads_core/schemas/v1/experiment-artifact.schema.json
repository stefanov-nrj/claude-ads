{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/experiment-artifact.schema.json", "title": "ExperimentArtifact v1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "created_at", "experiment_id", "stage", "design", "result", "decision", "status"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "experiment-artifact"}, "run_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "created_at": {"$ref": "workflow-common.schema.json#/$defs/datetime"}, "experiment_id": {"$ref": "workflow-common.schema.json#/$defs/id"}, "stage": {"enum": ["setup", "readout"]},
    "design": {"type": "object", "additionalProperties": false, "required": ["decision", "hypothesis", "treatment", "control", "randomization_unit", "population", "primary_metric", "guardrails", "minimum_effect", "stopping_rule", "exclusions"], "properties": {"decision": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "hypothesis": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "treatment": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "control": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "randomization_unit": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "population": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "primary_metric": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "guardrails": {"type": "array", "minItems": 1, "items": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}, "minimum_effect": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "stopping_rule": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "exclusions": {"$ref": "workflow-common.schema.json#/$defs/string_array"}}},
    "result": {"type": ["object", "null"], "additionalProperties": false, "required": ["assignment_integrity", "data_complete", "effect_estimate", "uncertainty", "evidence_refs"], "properties": {"assignment_integrity": {"type": "boolean"}, "data_complete": {"type": "boolean"}, "effect_estimate": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "uncertainty": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}, "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "workflow-common.schema.json#/$defs/nonempty"}}}},
    "decision": {"type": ["string", "null"]}, "status": {"$ref": "workflow-common.schema.json#/$defs/artifact_status"}
  }
}
