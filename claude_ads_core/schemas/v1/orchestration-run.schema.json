{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://ai-marketing-hub.github.io/claude-ads/schemas/v1/orchestration-run.schema.json", "title": "OrchestrationRun v1", "type": "object", "additionalProperties": false,
